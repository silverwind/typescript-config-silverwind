{
  "include": [
    "${configDir}/**/*",
    "${configDir}/**/.*",
    "${configDir}/**/.*/**/*",
    "${configDir}/**/.*/**/.*",
  ],
  "exclude": [
    "${configDir}/**/.air/**",
    "${configDir}/**/.git/**",
    "${configDir}/**/.make/**",
    "${configDir}/**/.ruff_cache/**",
    "${configDir}/**/.swc/**",
    "${configDir}/**/.venv/**",
    "${configDir}/**/build/**",
    "${configDir}/**/dist/**",
    "${configDir}/**/node_modules/**",
    "${configDir}/**/persistent/**",
  ],
  "compilerOptions": {
    "outDir": "dist", // for type definitions
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowArbitraryExtensions": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": false, // d.ts emit is handled by tsdown, not tsc/tsgo
    "declarationMap": false, // https://github.com/rolldown/tsdown/issues/504
    "erasableSyntaxOnly": true,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": false, // TODO
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": [], // disable automatic inclusion of all @types packages
    "lib": ["DOM", "DOM.Iterable", "DOM.AsyncIterable", "ESNext"],
    "libReplacement": false,
    "noEmit": true,
    "noPropertyAccessFromIndexSignature": false, // TODO
    "noUncheckedIndexedAccess": false, // TODO
    "noUncheckedSideEffectImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "stripInternal": true,
    "verbatimModuleSyntax": true,
    "pretty": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,

    "strict": true,
    "useUnknownInCatchVariables": false, // TODO
  }
}
